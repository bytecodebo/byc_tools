<templateSet group="OdooOldPython">
  <template name="odx_import" value="from odoo import models, fields, api, _&#10;" description="Add basic Odoo import for old Odoo versions" toReformat="false" toShortenFQNames="true">
    <context>
      <option name="Python" value="true" />
    </context>
  </template>
  <template name="odx_data" value="&lt;?xml version=&quot;1.0&quot; encoding=&quot;utf-8&quot;?&gt;&#10;&lt;odoo&gt;&#10;    &lt;data&gt;&#10;        &#10;        $stay_here$&#10;    &#10;    &lt;/data&gt;&#10;&lt;/odoo&gt;" description="Create the main tags" toReformat="false" toShortenFQNames="true">
    <variable name="stay_here" expression="" defaultValue="" alwaysStopAt="true" />
    <context />
  </template>
  <template name="odx_qweb_reports" value="&lt;!-- QWeb Reports --&gt;&#10;        &lt;report&#10;            id=&quot;UNIQUE_REPORT_ID&quot;&#10;            model=&quot;MODEL_WHERE_THE_REPORT_WILL_BE_PRINTED&quot;&#10;            report_type=&quot;qweb-pdf&quot;&#10;            string=&quot;LABEL&quot;&#10;            name=&quot;NAME&quot;&#10;            file=&quot;FILE_NAME&quot;&#10;        /&gt;" description="Add a declaration for new QWeb reports" toReformat="false" toShortenFQNames="true">
    <context />
  </template>
  <template name="odx_class" value="class $class_name$(models.Model):&#10;    _name = '$module_name$'&#10;    _description = '$class_name$'&#10;&#10;    name = fields.Char()&#10;    $END$&#10;" description="Create New Odoo Class" toReformat="true" toShortenFQNames="true">
    <variable name="class_name" expression="" defaultValue="" alwaysStopAt="true" />
    <variable name="module_name" expression="" defaultValue="" alwaysStopAt="true" />
    <context />
  </template>
</templateSet>