<templateSet group="other">
  <template name="todo" value="# TODO $DATE$ $USER$: $END$" description="Insert TODO comment with the current date and username" toReformat="false" toShortenFQNames="true">
    <variable name="DATE" expression="date()" defaultValue="None" alwaysStopAt="false" />
    <variable name="USER" expression="user()" defaultValue="None" alwaysStopAt="false" />
    <context>
      <option name="Python" value="true" />
      <option name="Python_Top_Level" value="false" />
    </context>
  </template>
  <template name="tg_lt" value="&amp;lt;" description="replace tags html like &lt; = &amp;lt;" toReformat="false" toShortenFQNames="true">
    <context>
      <option name="XML" value="true" />
    </context>
  </template>
  <template name="tg_gt" value="&amp;gt;" description="replace tags html like &gt;  &amp;gt;" toReformat="false" toShortenFQNames="true">
    <context>
      <option name="XML" value="true" />
    </context>
  </template>
  <template name="tg_q2" value="&amp;quot;" description="replace tags html doble quote  &amp;quot;" toReformat="false" toShortenFQNames="true">
    <context>
      <option name="XML" value="true" />
    </context>
  </template>
  <template name="tg_nl" value="&amp;#10;" description="replace tag to ascii new line = &amp;#10;" toReformat="false" toShortenFQNames="true">
    <context>
      <option name="XML" value="true" />
    </context>
  </template>
  <template name="tg_q2d" value="&amp;quot;$VAR$&amp;quot;" description="replace tags html double quote  &amp;quot; open and close" toReformat="false" toShortenFQNames="true">
    <variable name="VAR" expression="" defaultValue="" alwaysStopAt="true" />
    <context>
      <option name="XML" value="true" />
    </context>
  </template>
  <template name="tg_ltgt_end" value="&amp;lt;/$VAR$&amp;gt;" description="replace tags html like &lt;/tag_name&gt;" toReformat="false" toShortenFQNames="true">
    <variable name="VAR" expression="" defaultValue="" alwaysStopAt="true" />
    <context>
      <option name="XML" value="true" />
    </context>
  </template>
  <template name="tg_ltgt_start" value="&amp;lt;$TAG_NAME$&amp;gt;" description="replace tags html like &lt;tag_name&gt;" toReformat="false" toShortenFQNames="true">
    <variable name="TAG_NAME" expression="" defaultValue="" alwaysStopAt="true" />
    <context>
      <option name="XML" value="true" />
    </context>
  </template>
  <template name="tg_eq" value="&amp;#61;" description="replace tag html like `=` equal" toReformat="false" toShortenFQNames="true">
    <context>
      <option name="XML" value="true" />
    </context>
  </template>
  <template name="tg_true_val" value="&amp;quot;true&amp;quot;" description="add value true with double quotes" toReformat="false" toShortenFQNames="true">
    <context>
      <option name="XML" value="true" />
    </context>
  </template>
  <template name="tg_false_val" value="&amp;quot;false&amp;quot;" description="add value false with double quotes" toReformat="false" toShortenFQNames="true">
    <context>
      <option name="XML" value="true" />
    </context>
  </template>
  <template name="tg_field_name" value="&amp;lt;field name=&amp;quot;$VAR_NAME$&amp;quot; /&amp;gt;" description="add tag with field name e.g. &lt;field name=&quot;field_name&quot;&gt;" toReformat="false" toShortenFQNames="true">
    <variable name="VAR_NAME" expression="" defaultValue="&quot;$field_name$&quot;" alwaysStopAt="true" />
    <context>
      <option name="XML" value="true" />
    </context>
  </template>
  <template name="attr_name" value="$ATTR_NAME$=&amp;quot;$ATTR_VALUE$&amp;quot; " description="add tag with attr e.g. attr_name=&quot;$field_name$&quot;" toReformat="false" toShortenFQNames="true">
    <variable name="ATTR_NAME" expression="" defaultValue="&quot;name&quot;" alwaysStopAt="true" />
    <variable name="ATTR_VALUE" expression="" defaultValue="" alwaysStopAt="true" />
    <context>
      <option name="XML" value="true" />
    </context>
  </template>
  <template name="tg_var_value" value="$$$VAR_VALUE$$$ " description="add tag value e.g. &quot;$var_value$&quot;" toReformat="false" toShortenFQNames="true">
    <variable name="VAR_VALUE" expression="" defaultValue="&quot;field_&quot;" alwaysStopAt="true" />
    <context>
      <option name="XML" value="true" />
    </context>
  </template>
  <template name="tg_pass_value" value="&amp;quot;pass&amp;quot;" description="add tag pass value e.g. &amp;quot;pass&amp;quot;" toReformat="false" toShortenFQNames="true">
